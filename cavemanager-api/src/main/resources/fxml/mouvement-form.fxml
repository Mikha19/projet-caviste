<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cavemanager.controller.MouvementFormController"
      spacing="16" styleClass="form-root">

    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <Label fx:id="labelTitre" text="Mouvement de stock" styleClass="form-title"/>
    <Label fx:id="labelProduit" text="" styleClass="form-subtitle"/>
    <Label fx:id="labelStockActuel" text="" styleClass="form-stock"/>

    <Separator/>

    <GridPane hgap="12" vgap="12">
        <Label text="Quantité *" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="fieldQuantite" promptText="Ex: 6" prefWidth="120"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Commentaire" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="fieldCommentaire" promptText="Ex: BL n°12345 / Vente directe"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS"/>

        <columnConstraints>
            <ColumnConstraints minWidth="110" prefWidth="110"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
    </GridPane>

    <Label fx:id="labelErreur" styleClass="label-erreur" wrapText="true" visible="false"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#onAnnuler" styleClass="btn-secondary"/>
        <Button fx:id="btnConfirmer" text="✔ Confirmer" onAction="#onConfirmer"
                styleClass="btn-primary" defaultButton="true"/>
    </HBox>
</VBox>
