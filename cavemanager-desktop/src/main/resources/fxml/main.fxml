<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<!--
    Interface principale de CaveManager.
    Structure :
      ┌─────────────────────────────────────────┐
      │  HEADER : titre + compteurs              │
      ├─────────────────────────────────────────┤
      │  TOOLBAR : recherche + boutons actions   │
      ├─────────────────────────────────────────┤
      │  TABLE : liste des produits              │
      └─────────────────────────────────────────┘

    NOTE PÉDAGOGIQUE :
      fx:controller lie ce fichier FXML à MainController.kt
      fx:id lie chaque élément à une variable @FXML dans le contrôleur
      onAction="#methode" appelle la méthode @FXML correspondante
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cavemanager.controller.MainController"
            styleClass="root-pane">

    <!-- ===== EN-TÊTE ===== -->
    <top>
        <VBox styleClass="header">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="🍷 CaveManager Pro" styleClass="title-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelAlertes" text="✅ Stock OK" styleClass="label-alerte"/>
                <Label fx:id="labelNbProduits" text="0 produit(s)" styleClass="label-count"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===== CONTENU PRINCIPAL ===== -->
    <center>
        <VBox spacing="0">

            <!-- Barre d'outils -->
            <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>

                <!-- Recherche -->
                <TextField fx:id="textFieldRecherche"
                           promptText="🔍  Rechercher par nom, appellation, région..."
                           prefWidth="350"
                           styleClass="search-field"/>
                <Button text="✕" onAction="#onEffacerRecherche" styleClass="btn-clear"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Boutons CRUD -->
                <Button fx:id="btnAjouter" text="＋ Ajouter"
                        onAction="#onAjouter" styleClass="btn-primary"/>
                <Button fx:id="btnModifier" text="✏ Modifier"
                        onAction="#onModifier" styleClass="btn-secondary"/>
                <Button fx:id="btnSupprimer" text="🗑 Supprimer"
                        onAction="#onSupprimer" styleClass="btn-danger"/>
                <Separator orientation="VERTICAL"/>
                <Button fx:id="btnEntree" text="📦 Entrée"
                        onAction="#onEntreeStock" styleClass="btn-success"/>
                <Button fx:id="btnSortie" text="🛒 Sortie"
                        onAction="#onSortieStock" styleClass="btn-warning"/>
            </HBox>

            <!-- Table des produits -->

            <TableView fx:id="tableViewProduits" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="Aucun produit trouvé. Cliquez sur '+ Ajouter' pour commencer."
                           style="-fx-text-fill: #9E9E9E; -fx-font-size: 14px;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="220"/>
                    <TableColumn fx:id="colAppellation" text="Appellation" prefWidth="160"/>
                    <TableColumn fx:id="colMillesime" text="Millésime" prefWidth="90"/>
                    <TableColumn fx:id="colRegion" text="Région" prefWidth="130"/>
                    <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
                    <TableColumn fx:id="colPrixVente" text="Prix vente" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- ===== BARRE DE STATUT ===== -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
            <Label text="Double-clic sur un produit pour le modifier • Sélectionnez un produit pour les actions de stock"
                   styleClass="label-hint"/>
        </HBox>
    </bottom>

</BorderPane>
